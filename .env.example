# My Holiday — server environment variables
# Copy to .env and adjust as needed (never commit .env)

# Network interface the API binds to.
# 127.0.0.1 = localhost only (default, safe)
# 0.0.0.0   = all interfaces — only use this with an auth layer in front
API_HOST=127.0.0.1

# TCP port for the Express server
API_PORT=3001

# Database backend (ADR-0006):
# sqlite   = single-user default, zero dependencies
# postgres = required for multi-user mode (needs DATABASE_URL)
DB_DRIVER=sqlite

# Path to the SQLite database file (DB_DRIVER=sqlite)
DB_PATH=data/my-holiday.db

# PostgreSQL connection string (DB_DRIVER=postgres)
# DATABASE_URL=postgres://holiday:<password>@localhost:5432/holiday

# Password for the optional docker-compose postgres service — required by
# `docker compose --profile postgres up` (no default on purpose).
# POSTGRES_PASSWORD=<generate-a-strong-password>

# Allow one additional cross-origin origin (browser access from another host).
# By default only localhost / 127.0.0.1 / [::1] origins may call the API
# cross-origin; same-origin use (the served SPA) needs no CORS at all.
# CORS_ORIGIN=https://dashboard.example.lan

# Opt-in bearer-token auth (single-user mode only): when set, every /api/v1
# request must send "Authorization: Bearer <token>". The CLI supplies it via
# MY_HOLIDAY_API_TOKEN. The web UI does not attach tokens — use for CLI/API-only
# deployments. Rejected when AUTH_MODE=oidc (use personal access tokens).
# API_TOKEN=change-me

# ── Multi-user mode (ADR-0007) ────────────────────────────────────────────
# Opt-in OIDC authentication. AUTH_MODE=oidc requires DB_DRIVER=postgres and
# every variable below; the server fails fast at startup if any is missing.
# Leave AUTH_MODE=none (default) for the single-user app.
# AUTH_MODE=none

# OIDC issuer URL — discovery resolves the rest (Entra ID, Authentik, Keycloak).
# OIDC_ISSUER_URL=https://login.example.com/realms/staff
# OIDC_CLIENT_ID=my-holiday
# OIDC_CLIENT_SECRET=<client-secret>

# Externally reachable base URL; redirect URI is <PUBLIC_BASE_URL>/api/v1/auth/callback.
# PUBLIC_BASE_URL=https://holiday.example.com

# Random >=32-byte string signing the session cookie. Generate: openssl rand -base64 32
# SESSION_SECRET=<at-least-32-bytes>

# Comma-separated emails granted admin on first (verified-email) login.
# ADMIN_EMAILS=you@example.com

# Session / refresh token lifetimes in seconds (defaults: 900 = 15 min, 30 days).
# ACCESS_TOKEN_TTL_S=900
# REFRESH_TOKEN_TTL_S=2592000
