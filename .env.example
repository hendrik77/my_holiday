# My Holiday — server environment variables
# Copy to .env and adjust as needed (never commit .env)

# Network interface the API binds to.
# 127.0.0.1 = localhost only (default, safe)
# 0.0.0.0   = all interfaces — only use this with an auth layer in front
API_HOST=127.0.0.1

# TCP port for the Express server
API_PORT=3001

# Path to the SQLite database file
DB_PATH=data/my-holiday.db

# Restrict CORS to a specific origin (recommended in production).
# Leave unset to allow any origin (fine for localhost-only use).
# CORS_ORIGIN=http://localhost:5173
