# My Holiday — server environment variables
# Copy to .env and adjust as needed (never commit .env)

# Network interface the API binds to.
# 127.0.0.1 = localhost only (default, safe)
# 0.0.0.0   = all interfaces — only use this with an auth layer in front
API_HOST=127.0.0.1

# TCP port for the Express server
API_PORT=3001

# Database backend (ADR-0006):
# sqlite   = single-user default, zero dependencies
# postgres = required for multi-user mode (needs DATABASE_URL)
DB_DRIVER=sqlite

# Path to the SQLite database file (DB_DRIVER=sqlite)
DB_PATH=data/my-holiday.db

# PostgreSQL connection string (DB_DRIVER=postgres)
# DATABASE_URL=postgres://holiday:change-me@localhost:5432/holiday

# Allow one additional cross-origin origin (browser access from another host).
# By default only localhost / 127.0.0.1 / [::1] origins may call the API
# cross-origin; same-origin use (the served SPA) needs no CORS at all.
# CORS_ORIGIN=https://dashboard.example.lan

# Opt-in bearer-token auth: when set, every /api/v1 request must send
# "Authorization: Bearer <token>". The CLI supplies it via MY_HOLIDAY_API_TOKEN.
# Note: the web UI does not attach tokens — use for CLI/API-only deployments.
# API_TOKEN=change-me
